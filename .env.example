# Required: OpenAI key used server-side for AI opinions
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override default model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Market data provider. Options:
#   yahoo         — default. No key required. Real-time prices + day change for
#                   stocks, ETFs, indices, and FX via Yahoo Finance.
#   alpha-vantage — requires ALPHA_VANTAGE_API_KEY below.
MARKET_DATA_PROVIDER=yahoo

# Only needed if MARKET_DATA_PROVIDER=alpha-vantage
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
